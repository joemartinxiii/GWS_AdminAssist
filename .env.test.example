# Copy to .env.test and fill in values. Never commit .env.test.
# See docs/STAGING_TEST_SETUP.md for Workspace test resource setup.

# --- Required for live API + E2E tests ---
TEST_SUPER_ADMIN_EMAIL=your-super-admin@yourdomain.com
JWT_SECRET=your-jwt-secret-must-match-backend
GCP_PROJECT_ID=your-gcp-project-id
WORKSPACE_DOMAIN=yourdomain.com
GWS_ALLOWED_DOMAINS=yourdomain.com

# Keyless domain-wide delegation: the runtime service account the app signs as.
# Locally, run `gcloud auth application-default login` and ensure that identity
# has roles/iam.serviceAccountTokenCreator on this SA. No key file is used.
SERVICE_ACCOUNT_EMAIL=workspace-admin-sa@your-gcp-project-id.iam.gserviceaccount.com

# OAuth (required for backend startup; use dev client values)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/callback
CORS_ORIGIN=http://localhost:3000

# --- Optional stable test resource IDs (create once in Workspace) ---
TEST_GROUP_EMAIL=gws-test-group@yourdomain.com
TEST_USER_EMAIL=gws-test-user@yourdomain.com
TEST_MY_DRIVE_FILE_ID=
TEST_SHARED_DRIVE_FILE_ID=
TEST_SHARED_DRIVE_ID=
TEST_DELEGATION_TARGET_EMAIL=

# --- Gates ---
# Set true to run @mutating tests (writes + cleanup)
TEST_MUTATIONS=false

# Backend port for dev / Playwright webServer
PORT=5001
NODE_ENV=development
