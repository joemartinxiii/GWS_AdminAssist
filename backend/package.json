{
  "name": "workspace-admin-backend",
  "version": "1.0.0",
  "description": "Backend API for Google Workspace Admin UI",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:ci": "eslint src --quiet",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:security": "jest tests/security-validation.test.ts",
    "test:watch": "jest --watch",
    "test:live": "jest -c jest.live.config.js --runInBand",
    "test:live:read": "jest -c jest.live.config.js --runInBand --testNamePattern=@read"
  },
  "dependencies": {
    "@google-cloud/logging": "^11.2.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^7.17.0",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dompurify": "^3.3.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "googleapis": "^128.0.0",
    "helmet": "^7.1.0",
    "jsdom": "^27.4.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  }
}
